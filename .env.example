# Copy to .env and adjust for your machine before running local or Docker workflows.

MGP_HOST=0.0.0.0
MGP_PORT=18080
MGP_API_PREFIX=/api/v1
MGP_FRONTEND_PORT=5173

MGP_POSTGRES_HOST=127.0.0.1
MGP_POSTGRES_PORT=5432
MGP_POSTGRES_DB=mvp_push_gateway_dev
MGP_TEST_POSTGRES_DB=mvp_push_gateway_test
MGP_POSTGRES_USER=mvp_push_gateway
MGP_POSTGRES_PASSWORD=change-me-dev-password
MGP_POSTGRES_SSLMODE=disable

MGP_POSTGRES_DSN=postgres://${MGP_POSTGRES_USER}:${MGP_POSTGRES_PASSWORD}@${MGP_POSTGRES_HOST}:${MGP_POSTGRES_PORT}/${MGP_POSTGRES_DB}?sslmode=${MGP_POSTGRES_SSLMODE}
MGP_TEST_DATABASE_URL=postgres://${MGP_POSTGRES_USER}:${MGP_POSTGRES_PASSWORD}@${MGP_POSTGRES_HOST}:${MGP_POSTGRES_PORT}/${MGP_TEST_POSTGRES_DB}?sslmode=${MGP_POSTGRES_SSLMODE}

# Optional docker compose project name override.
COMPOSE_PROJECT_NAME=mvp-push-gateway
